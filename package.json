{
  "name": "barkan-web",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "pm2:start-prod-api": "pm2 startOrReload ecosystem.config.cjs --only prod-barkan-api --update-env && pm2 save",
    "pm2:list": "pm2 list",
    "build": "npm --workspaces --if-present run build",
    "deploy:barkan-web": "bash scripts/deploy-barkan-web.sh",
    "deploy-barkan-web": "npm run deploy:barkan-web",
    "deploy:barkan-widget": "bash scripts/deploy-barkan-widget.sh",
    "deploy-barkan-widget": "npm run deploy:barkan-widget",
    "test": "npm --workspaces --if-present run test",
    "lint": "npm --workspaces --if-present run lint"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
