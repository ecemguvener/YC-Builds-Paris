{
  "name": "barkan",
  "version": "0.1.0",
  "description": "Barkan CLI",
  "type": "module",
  "bin": {
    "barkan": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "node ../../node_modules/typescript/lib/tsc.js -p tsconfig.json && (chmod 775 dist/index.js 2>/dev/null || true)",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --pretty false"
  },
  "dependencies": {
    "picocolors": "^1.1.1",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=18"
  }
}
